# ============================================================
# SocialHub — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Django environment: development | production
DJANGO_ENV=development

# Secret key — generate one at: https://djecrety.ir/
# Example: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-replace-me

# ---- Development (SQLite, no extra config needed) ----
# DEBUG is True automatically in development mode.

# ---- Production only (uncomment & fill when deploying) ----
# DJANGO_ENV=production
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# PostgreSQL connection string (Render / Railway provide this automatically)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cloudinary (for media storage in production)
# Get these from: https://cloudinary.com/console
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Email (optional — for password reset etc.)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

